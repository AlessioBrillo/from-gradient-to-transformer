{
  "line-length": {
    "line_length": 120,
    "code_blocks": false,
    "tables": false,
    "strict": false
  },
  "no-bare-urls": false,
  "no-trailing-punctuation": {
    "punctuation": ".,;:!。，；：！"
  },
  "no-duplicate-heading": {
    "siblings_only": true
  },
  "no-inline-html": false,
  "single-trailing-newline": false,
  "ul-indent": {
    "indent": 2
  },
  "no-multiple-blanks": {
    "maximum": 2
  }
}
